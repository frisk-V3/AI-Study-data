# --- GitHub Actions 実行時の生成物 ---
dist/
build/
bin/
obj/

# --- 学習ログや一時ファイル ---
# 実行するたびに書き換わるログファイル
*.log
logs/
checkpoints/

# --- 依存関係 (Actions実行時にインストールされるもの) ---
node_modules/
.venv/
env/
lib/
lib64/

# --- AI学習の「途中経過」 ---
# 1日1回の学習で生成される一時的な重みデータ
temp_model/
*.tmp
*.cache

# --- シークレット情報 (絶対に上げちゃダメ) ---
.env
secrets.json
